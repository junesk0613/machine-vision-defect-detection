def delete_chat_message(line_id, msg_id):
    data = _load(f'chat_{line_id}.json', [])
    target = None
    for m in data:
        if m.get('id') == msg_id:
            target = m
            break
    if not target:
        return False
    if target.get('file_name'):
        fp = os.path.join(CHAT_FILE_DIR, target['file_name'])
        if os.path.exists(fp):
