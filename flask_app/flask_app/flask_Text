def login_required(f):
    from functools import wraps
    @wraps(f)
    def d(*a, **k):
        if 'user_id' not in session: return redirect(url_for('login'))
        return f(*a, **k)
    return d

def super_admin_required(f):
    from functools import wraps
    @wraps(f)
    def d(*a, **k):
        if 'user_id' not in session: return redirect(url_for('login'))
        if session.get('role') != 'super_admin': return jsonify({'error': '권한 없음'}), 403
        return f(*a, **k)
    return d

