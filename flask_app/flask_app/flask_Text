import os, json, threading
from datetime import datetime, timedelta

DATA_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'data')
os.makedirs(DATA_DIR, exist_ok=True)

_lock = threading.Lock()

DEFAULT_POLICY = {
    'factory': {
        'company': '○○전자',
